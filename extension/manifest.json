{
  "manifest_version": 3,
  "name": "UT Schedule Builder",
  "version": "1.0.0",
  "description": "Generate all possible class schedules from UT Austin's course catalog. Just enter your courses and go.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://utdirect.utexas.edu/apps/registrar/course_schedule/*",
    "https://catalog.utexas.edu/ribbit/*",
    "https://catalog.utexas.edu/general-information/coursesatoz/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
